# GCP Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_KEY_FILE=./gcp-key.json
BIGQUERY_DATASET=empirika
BIGQUERY_LOCATION=US

# YouTube API Credentials (OAuth2)
# Create at: https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID=your-youtube-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:5000/auth/callback

# Claude API (Anthropic)
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# TikTok Research API (optional – Week 3)
TIKTOK_API_KEY=your-tiktok-api-key

# Reddit API (optional – Week 3)
# Create at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=empirika-bot/1.0

# Backend server port
PORT=5000
