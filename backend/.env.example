# TikTok API (Week 3)
TIKTOK_API_KEY=

# Reddit API (Week 3)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=empirika-bot/1.0

# Server
PORT=5000
NODE_ENV=development
