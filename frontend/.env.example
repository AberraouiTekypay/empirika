# GCP Configuration (server-side only)
GCP_PROJECT_ID=your-gcp-project-id
GCP_KEY_FILE=./gcp-key.json
BIGQUERY_DATASET=empirika
BIGQUERY_LOCATION=US

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Backend service URL (used by admin sync proxy)
BACKEND_URL=http://localhost:5000

# Admin secret (protect the /api/admin/sync endpoint)
ADMIN_SECRET=change-this-to-a-strong-secret

# Public env vars (exposed to browser via next.config.js)
NEXT_PUBLIC_API_URL=http://localhost:5000
